{
  "name": "bun-stack",
  "version": "0.1.0",
  "description": "",
  "keywords": [
    "typescript",
    "bun"
  ],
  "engines": {
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "bootstrap:build": "bun run build-bootstrap.ts",
    "build:full": "bun run bootstrap:build && bun run build.ts",
    "build": "bun run build.ts",
    "watch": "bun --watch run build.ts",
    "lint": "biome lint .",
    "format": "biome format --write . && prettier --write \"src/**/*.scss\"",
    "check": "biome check . && prettier --check \"src/**/*.scss\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "1.3.12",
    "@types/twig": "^1.12.17",
    "fast-glob": "^3.3.3",
    "prettier": "^3.8.3",
    "sass": "^1.93.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bun": "^1.3.12",
    "twig": "^3.0.0"
  }
}
