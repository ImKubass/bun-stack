root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 140

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.php]
indent_style = space
indent_size = 4

[composer.{json,lock}]
indent_size = 4
